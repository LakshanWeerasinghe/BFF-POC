# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ── APIM toggle ─────────────────────────────────────────────────────────────
# Set to true to route all API calls through WSO2 APIM.
APIM_ENABLED=false

# ── APIM proxy targets (Vite config / Node only) ─────────────────────────────
APIM_GATEWAY_URL=https://localhost:8243
APIM_TOKEN_URL=https://localhost:9443

# ── APIM application credentials (in browser bundle — keep in mind for prod) ─
VITE_APIM_ENABLED=false
VITE_APIM_CLIENT_ID=your_consumer_key_here
VITE_APIM_CLIENT_SECRET=your_consumer_secret_here

# ── Direct service URLs (used when APIM_ENABLED=false) ───────────────────────
AUTH_SERVICE_URL=http://localhost:9090
BACKEND_URL=http://localhost:8080
